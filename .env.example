# ============================================================
# 崂山茶展陈顾问 · 环境变量配置
# 首次使用请双击 setup.bat 或直接填写以下内容
# ============================================================

# 前端 / 后端端口（通常不需要修改）
VITE_BACKEND_PORT=3001
VITE_FRONTEND_PORT=3000

# --- 腾讯云密钥（SecretId / SecretKey）---
# 获取地址: https://console.cloud.tencent.com/cam/capi
VITE_SECRET_ID=填入你的腾讯SecretId
VITE_SECRET_KEY=填入你的腾讯SecretKey

# --- Google API Key ---
# 获取地址: https://aistudio.google.com/app/apikey
VITE_GOOGLE_API_KEY=填入你的Google API Key

# 后端专用（不要改动）
PORT=3001
FRONTEND_PORT=3000
